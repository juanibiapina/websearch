{
  "name": "@juanibiapina/websearch",
  "version": "2.1.0",
  "description": "Multi-provider web search and content extraction CLI",
  "author": "Juan Ibiapina",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juanibiapina/websearch.git"
  },
  "type": "module",
  "bin": {
    "websearch": "dist/websearch.js"
  },
  "files": [
    "dist/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "check": "tsc --noEmit",

    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "commander": "^15.0.0",
    "jsdom": "^29.1.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/jsdom": "^28.0.3",
    "@types/turndown": "^5.0.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
